<?xml version="1.0" encoding="utf-8"?>
<!-- Android 11 and lower. Require client-side encryption because Tomera can
     contain client, calendar, notes, and finance data. -->
<full-backup-content>
    <include
        domain="root"
        path="app_flutter/tomera.sqlite"
        requireFlags="clientSideEncryption" />
    <include
        domain="sharedpref"
        path="FlutterSharedPreferences.xml"
        requireFlags="clientSideEncryption" />
</full-backup-content>
